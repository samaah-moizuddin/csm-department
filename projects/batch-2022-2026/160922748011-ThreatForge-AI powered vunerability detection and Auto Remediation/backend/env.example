# ──────────────────────────────────────────────────────────────
# CognitoForge Labs — Environment Variables
# Copy this to .env and fill in real values. Never commit .env!
# ──────────────────────────────────────────────────────────────

# ── Supabase / PostgreSQL ──────────────────────────────────────
DB_HOST=your-supabase-db-host.supabase.co
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_PORT=5432

# ── Google Gemini ──────────────────────────────────────────────
COGNITOFORGE_GEMINI_API_KEY=your_gemini_api_key
COGNITOFORGE_USE_GEMINI=false
# COGNITOFORGE_GEMINI_MODEL=gemini-2.0-flash-thinking-exp-1219

# ── GitHub (optional, avoids rate limits) ─────────────────────
COGNITOFORGE_GITHUB_TOKEN=ghp_your_github_token

# ── CORS — add your Vercel URL here ───────────────────────────
# Comma-separated list of allowed origins
COGNITOFORGE_ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Auth0 (optional) ──────────────────────────────────────────
# COGNITOFORGE_AUTH0_DOMAIN=your-tenant.auth0.com
# COGNITOFORGE_AUTH0_CLIENT_ID=your_client_id
